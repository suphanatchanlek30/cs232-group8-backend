APP_NAME=TU Pulse Backend
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/api/v1

POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_EXPOSE_PORT=5435
POSTGRES_DB=tu_pulse
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/tu_pulse

JWT_SECRET_KEY=super-secret-access-key-change-this
JWT_REFRESH_SECRET_KEY=super-secret-refresh-key-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

LINE_VERIFY_MODE=real
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_LIFF_ID=

CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:5173

AUTO_CREATE_TABLES=true